# Environment variables for Paper Trader League

# Exchange / market data placeholders
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
NEWSAPI_KEY=
ALPHAVANTAGE_KEY=
TWITTER_BEARER_TOKEN=
# Options: synthetic | coinbase
# coinbase uses the public Coinbase Exchange REST API (no key needed for prices)
MARKET_DATA_SOURCE=synthetic
# Optional: Coinbase Advanced Trade API credentials (for future authenticated endpoints)
CB_API_KEY=
CB_API_SECRET=

# Runtime controls
AUTO_BOOTSTRAP_SEASON=true
INGEST_LOOP_SECONDS=5
SYNTHETIC_SEED=42
SYNTHETIC_HISTORY_SIZE=180
TRADE_ENGINE_URL=http://trade_engine:8088

# Database
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_USER=paperbot
POSTGRES_PASSWORD=paperbot
POSTGRES_DB=paperbot

# Season / simulator defaults
DEFAULT_SEASON_ID=season-001
DEFAULT_STARTING_BTC=0.05
DEFAULT_FEE_BPS=10
DEFAULT_SLIPPAGE_BPS=5

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
