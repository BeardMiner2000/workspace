          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH roster AS ( SELECT season_id, bot_id, bot_name, status FROM season_bots WHERE season_id IN ('season-002', 'season-003', 'season-004') ), first_metric AS ( SELECT DISTINCT ON (season_id, bot_id) season_id, bot_id, equity_btc AS start_equity FROM bot_metrics WHERE season_id IN ('season-002', 'season-003', 'season-004') ORDER BY season_id, bot_id, ts ASC ), latest_metric AS ( SELECT DISTINCT ON (season_id, bot_id) season_id, bot_id, equity_btc, realized_pnl_btc, drawdown_pct, trade_count, ts FROM bot_metrics WHERE season_id IN ('season-002', 'season-003', 'season-004') ORDER BY season_id, bot_id, ts DESC ), scored AS ( SELECT r.season_id AS season, COALESCE(r.bot_name, r.bot_id) AS driver, r.bot_id, CASE WHEN r.status IN ('active', 'ready') THEN 'RUNNING' ELSE 'DNF' END AS race_status, ROUND((((l.equity_btc / NULLIF(f.start_equity, 0)) - 1) * 100)::numeric, 4) AS pct_gain, l.equity_btc, l.realized_pnl_btc, l.trade_count, l.drawdown_pct, l.ts AS last_seen FROM roster r LEFT JOIN first_metric f USING (season_id, bot_id) LEFT JOIN latest_metric l USING (season_id, bot_id) ) SELECT CASE WHEN race_status = 'RUNNING' THEN ROW_NUMBER() OVER (ORDER BY CASE WHEN race_status = 'RUNNING' THEN 0 ELSE 1 END, pct_gain DESC NULLS LAST, equity_btc DESC NULLS LAST) END AS position, season, driver, bot_id, race_status, pct_gain, equity_btc, realized_pnl_btc, trade_count, drawdown_pct, last_seen FROM scored ORDER BY CASE WHEN race_status = 'RUNNING' THEN 0 ELSE 1 END, pct_gain DESC NULLS LAST, equity_btc DESC NULLS LAST, season ASC, driver ASC;",
          "refId": "A"
        }
      ],
      "title": "Grid Classification",
      "type": "table"
