          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH roster AS ( SELECT season_id, bot_id, bot_name, status FROM season_bots WHERE season_id IN ('season-002', 'season-003', 'season-004') ), first_metric AS ( SELECT DISTINCT ON (season_id, bot_id) season_id, bot_id, equity_btc AS start_equity FROM bot_metrics WHERE season_id IN ('season-002', 'season-003', 'season-004') ORDER BY season_id, bot_id, ts ASC ), latest_metric AS ( SELECT DISTINCT ON (season_id, bot_id) season_id, bot_id, equity_btc FROM bot_metrics WHERE season_id IN ('season-002', 'season-003', 'season-004') ORDER BY season_id, bot_id, ts DESC ) SELECT CONCAT(REPLACE(r.season_id, 'season-00', 'S'), ' / ', COALESCE(r.bot_name, r.bot_id)) AS value FROM roster r JOIN first_metric f USING (season_id, bot_id) JOIN latest_metric l USING (season_id, bot_id) WHERE r.status IN ('active', 'ready') ORDER BY ((l.equity_btc / NULLIF(f.start_equity, 0)) - 1) DESC, l.equity_btc DESC LIMIT 1;",
