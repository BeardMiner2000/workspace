          "rawQuery": true,
          "rawSql": "WITH active_roster AS ( SELECT season_id, bot_id, bot_name FROM season_bots WHERE season_id IN ('season-002', 'season-003', 'season-004') AND status IN ('active', 'ready') ), first_metric AS ( SELECT DISTINCT ON (season_id, bot_id) season_id, bot_id, equity_btc AS start_equity FROM bot_metrics WHERE season_id IN ('season-002', 'season-003', 'season-004') ORDER BY season_id, bot_id, ts ASC ) SELECT m.ts AS time, ROUND((((m.equity_btc / NULLIF(f.start_equity, 0)) - 1) * 100)::numeric, 4) AS value, CONCAT(REPLACE(m.season_id, 'season-00', 'S'), ' / ', COALESCE(r.bot_name, m.bot_id)) AS metric FROM bot_metrics m JOIN active_roster r USING (season_id, bot_id) JOIN first_metric f USING (season_id, bot_id) WHERE $__timeFilter(m.ts) ORDER BY m.ts ASC;",
